# ──────────────────────────────────────────────────────────────────────────────
# GameOver Web Client — Environment Variables
# Copy this file to .env and configure for your environment
# ──────────────────────────────────────────────────────────────────────────────

# Backend API URL (leave empty to use localStorage mock for demo/offline use)
VITE_API_URL=http://localhost:4000

# Local print bridge (native ticket print via ESC/POS on localhost)
VITE_PRINTBRIDGE_URL=http://127.0.0.1:17890
VITE_PRINTBRIDGE_TOKEN=
# ──────────────────────────────────────────────────────────────────────────────
# GameOver API — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://gameover:gameover@localhost:5432/gameover?schema=public"

# JWT Secrets — CHANGE THESE IN PRODUCTION
JWT_SECRET="super-secret-jwt-access-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-key-change-in-production"
JWT_REFRESH_EXPIRY="7d"

# Frontend origin for CORS
CORS_ORIGIN="http://192.168.0.111:5173"

# Optional: folder where print-bridge Windows installers (.exe) are generated
# Default (if unset): ../print-bridge/release
PRINT_BRIDGE_INSTALLER_DIR="../print-bridge/release"

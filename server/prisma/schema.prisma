generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  fullName         String
  username         String         @unique
  email            String         @unique
  phone            String?
  role             UserRole       @default(vendedor)
  status           UserStatus     @default(activo)
  passwordHash     String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  parentId         String?
  planId           String?
  auditLogs        AuditLog[]
  masterOfPlans    Plan[]         @relation("PlanMaster")
  refreshTokens    RefreshToken[]
  associateTickets Ticket[]       @relation("AssociateTickets")
  canceledTickets  Ticket[]       @relation("CanceledTickets")
  soldTickets      Ticket[]       @relation("SellerTickets")
  parent           User?          @relation("UserHierarchy", fields: [parentId], references: [id])
  children         User[]         @relation("UserHierarchy")
  plan             Plan?          @relation("PlanUsers", fields: [planId], references: [id])

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  tokenId   String   @unique @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Plan {
  id         String   @id @default(cuid())
  name       String
  multiplier Float
  commission Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  masterId   String?
  master     User?    @relation("PlanMaster", fields: [masterId], references: [id])
  users      User[]   @relation("PlanUsers")

  @@map("plans")
}

model Draw {
  id                String             @id @default(cuid())
  name              String
  openTime          DateTime
  closeTime         DateTime
  winnerNumber      String?
  status            DrawStatus         @default(pendiente)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  restrictedNumbers RestrictedNumber[]
  tickets           Ticket[]

  @@map("draws")
}

model RestrictedNumber {
  id     String @id @default(cuid())
  number String
  limit  Float
  drawId String
  draw   Draw   @relation(fields: [drawId], references: [id], onDelete: Cascade)

  @@unique([drawId, number])
  @@map("restricted_numbers")
}

model Ticket {
  id           String       @id @default(cuid())
  code         String       @unique
  customerName String
  total        Float
  createdAt    DateTime     @default(now())
  printedAt    DateTime?
  drawId       String
  sellerId     String
  associateId  String
  cancelReason String?
  canceledAt   DateTime?
  canceledById String?
  lines        TicketLine[]
  associate    User         @relation("AssociateTickets", fields: [associateId], references: [id])
  canceledBy   User?        @relation("CanceledTickets", fields: [canceledById], references: [id])
  draw         Draw         @relation(fields: [drawId], references: [id])
  seller       User         @relation("SellerTickets", fields: [sellerId], references: [id])

  @@map("tickets")
}

model TicketLine {
  id             String  @id @default(cuid())
  number         String
  amount         Float
  isNicaEspecial Boolean @default(false)
  ticketId       String
  ticket         Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_lines")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum UserRole {
  admin
  asociado
  vendedor
}

enum UserStatus {
  activo
  bloqueado
  archivado
}

enum DrawStatus {
  pendiente
  abierto
  cerrado
  finalizado
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                  @id @default(cuid())
  fullName                 String
  username                 String                  @unique
  email                    String                  @unique
  phone                    String?
  role                     UserRole                @default(vendedor)
  status                   UserStatus              @default(activo)
  passwordHash             String
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  parentId                 String?
  planId                   String?
  auditLogs                AuditLog[]
  masterOfPlans            Plan[]                  @relation("PlanMaster")
  refreshTokens            RefreshToken[]
  associateTickets         Ticket[]                @relation("AssociateTickets")
  canceledTickets          Ticket[]                @relation("CanceledTickets")
  paidTickets              Ticket[]                @relation("PaidTickets")
  soldTickets              Ticket[]                @relation("SellerTickets")
  parent                   User?                   @relation("UserHierarchy", fields: [parentId], references: [id])
  children                 User[]                  @relation("UserHierarchy")
  plan                     Plan?                   @relation("PlanUsers", fields: [planId], references: [id])
  cashMovementsCreated     CashMovement[]          @relation("CashMovementsCreatedBy")
  cashMovementsTarget      CashMovement[]          @relation("CashMovementsTargetUser")
  cashMovementsCanceled    CashMovement[]          @relation("CashMovementsCanceledBy")
  announcementsCreated     Announcement[]          @relation("AnnouncementCreatedBy")
  announcementDismissals   AnnouncementDismissal[]
  restrictionLimits        UserRestrictionLimit?

  @@map("users")
}

model UserRestrictionLimit {
  id                String   @id @default(cuid())
  userId            String   @unique
  userGlobalLimit   Float?
  userDrawSaleLimit Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_restriction_limits")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  tokenId   String   @unique @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Plan {
  id         String   @id @default(cuid())
  name       String
  multiplier Float
  commission Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  masterId   String?
  master     User?    @relation("PlanMaster", fields: [masterId], references: [id])
  users      User[]   @relation("PlanUsers")

  @@map("plans")
}

model RolePermission {
  id          String   @id @default(cuid())
  resourceKey String
  role        UserRole
  allowed     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([resourceKey, role])
  @@map("role_permissions")
}

model SystemSetting {
  key       String   @id
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model Draw {
  id                  String             @id @default(cuid())
  name                String
  openTime            DateTime?
  closeTime           DateTime
  minutosPreviosCierre Int               @default(10)
  winnerNumber        String?
  status              DrawStatus         @default(pendiente)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  specialMultiplierId String?
  specialMultiplier   SpecialMultiplier? @relation(fields: [specialMultiplierId], references: [id], onDelete: SetNull)
  restrictedNumbers   RestrictedNumber[]
  tickets             Ticket[]

  @@map("draws")
}

model RestrictedNumber {
  id     String @id @default(cuid())
  number String
  limit  Float
  drawId String
  draw   Draw   @relation(fields: [drawId], references: [id], onDelete: Cascade)

  @@unique([drawId, number])
  @@map("restricted_numbers")
}

model Ticket {
  id            String            @id @default(cuid())
  code          String            @unique
  customerName  String
  total         Float
  createdAt     DateTime          @default(now())
  printedAt     DateTime?
  drawId        String
  sellerId      String
  associateId   String
  cancelReason  String?
  canceledAt    DateTime?
  canceledById  String?
  paymentStatus TicketPaymentStatus @default(pendiente)
  paidAt        DateTime?
  paidById      String?
  lines         TicketLine[]
  associate     User              @relation("AssociateTickets", fields: [associateId], references: [id])
  canceledBy    User?             @relation("CanceledTickets", fields: [canceledById], references: [id])
  draw          Draw              @relation(fields: [drawId], references: [id])
  seller        User              @relation("SellerTickets", fields: [sellerId], references: [id])
  paidBy        User?             @relation("PaidTickets", fields: [paidById], references: [id])

  @@map("tickets")
}

model TicketLine {
  id             String  @id @default(cuid())
  number         String
  amount         Float
  specialAmount  Float?
  isNicaEspecial Boolean @default(false)
  ticketId       String
  ticket         Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_lines")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SpecialMultiplier {
  id        String   @id @default(cuid())
  name      String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  draws     Draw[]

  @@map("special_multipliers")
}

model CashMovement {
  id          String           @id @default(cuid())
  targetUserId String
  createdById String
  type        CashMovementType
  amount      Float
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  canceledAt  DateTime?
  canceledById String?
  createdBy   User             @relation("CashMovementsCreatedBy", fields: [createdById], references: [id])
  targetUser  User             @relation("CashMovementsTargetUser", fields: [targetUserId], references: [id])
  canceledBy  User?            @relation("CashMovementsCanceledBy", fields: [canceledById], references: [id])

  @@map("cash_movements")
}

model Announcement {
  id          String                  @id @default(cuid())
  name        String
  message     String?
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  createdById String
  createdBy   User                    @relation("AnnouncementCreatedBy", fields: [createdById], references: [id])
  dismissals  AnnouncementDismissal[]

  @@map("announcements")
}

model AnnouncementDismissal {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  createdAt      DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@map("announcement_dismissals")
}

enum UserRole {
  admin
  asociado
  vendedor
}

enum UserStatus {
  activo
  bloqueado
  archivado
}

enum DrawStatus {
  pendiente
  abierto
  cerrado
  finalizado
}

enum TicketPaymentStatus {
  pendiente
  pagado
}

enum CashMovementType {
  deposito
  retiro
}
